{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quota Float",
  "version": "0.1.4",
  "identifier": "app.quotafloat.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "widget",
        "title": "Quota Float",
        "width": 88,
        "height": 88,
        "minWidth": 88,
        "minHeight": 88,
        "maxWidth": 328,
        "maxHeight": 328,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:" }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Codex quota at a glance",
    "longDescription": "A lightweight floating desktop card for Codex usage limits.",
    "copyright": "Copyright Quota Float contributors",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCQTgyODZCRjRFRDBFOTIKUldTU0R1MzBheWlvYXdHL0gxaStOd1h4K0RGOVljdkFIaTk0VFRkeWpBOUpIRW5WWEpLRm5ucFEK",
      "endpoints": ["https://github.com/change-42-yhmm/quota-float/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
